# Copy to apps/api/.env for local dev. docker-compose's `db` service matches these credentials.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kin?schema=public"

PORT=3000
WEB_ORIGIN="http://localhost:5173"

# CoinGecko free public API — no key required
UPSTREAM_BASE_URL="https://api.coingecko.com/api/v3"

REFRESH_MS=15000
STALE_THRESHOLD_MS=30000

# Set true to simulate an upstream outage (proves graceful degradation)
SIMULATE_UPSTREAM_DOWN=false
